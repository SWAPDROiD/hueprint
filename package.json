{
  "name": "hueprint",
  "version": "0.1.4",
  "description": "Universal terminal and web styling toolkit for Node.js with ANSI colors, HTML rendering, gradients, frameworks-friendly style objects, and developer logging.",
  "keywords": [
    "hueprint",
    "hue",
    "ansi",
    "colors",
    "terminal",
    "console",
    "logger",
    "cli",
    "nodejs",
    "text styling",
    "gradient text",
    "developer tools",
    "console styling",
    "terminal colors",
    "html styling",
    "style objects",
    "web styling",
    "react styling",
    "angular styling",
    "vue styling",
    "css-in-js",
    "universal styling",
    "multi-target rendering",
    "javascript",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./gradient": {
      "types": "./dist/gradient/index.d.ts",
      "import": "./dist/gradient/index.js",
      "require": "./dist/gradient/index.cjs"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "import": "./dist/logger/index.js",
      "require": "./dist/logger/index.cjs"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js",
      "require": "./dist/theme/index.cjs"
    },
    "./html": {
      "types": "./dist/html/index.d.ts",
      "import": "./dist/html/index.js",
      "require": "./dist/html/index.cjs"
    },
    "./object": {
      "types": "./dist/object/index.d.ts",
      "import": "./dist/object/index.js",
      "require": "./dist/object/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config build.config.ts",
    "clean": "rm -rf dist",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
